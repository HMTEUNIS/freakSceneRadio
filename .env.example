# Base URL to your VPS (or CDN) where audio files are stored. No trailing slash.
# Example: https://media.yourdomain.com/radio
AUDIO_FILES_BASE_URL=

# Suffix added to episode `id` when `file` is not set (server + client).
# Duplicate as NEXT_PUBLIC_* so the browser can build the same path as the API.
AUDIO_FILE_EXTENSION=.mp3
NEXT_PUBLIC_AUDIO_FILE_EXTENSION=.mp3
